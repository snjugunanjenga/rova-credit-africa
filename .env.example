# ─── Database (Cloud SQL via Supabase bridge during migration) ────────
# During migration: these point to Supabase. Post-migration: FastAPI API.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_PROJECT_ID="your-project-id"

# Post-migration: Cloud SQL via FastAPI
# VITE_DATABASE_API_URL="https://api.rovacredit.africa/v1"
# VITE_DATABASE_API_KEY="your-api-key"
# DATABASE_URL="postgresql://api_user@/rovacredit?host=/cloudsql/rovacredit:africa-east1:rovacredit-prod"

# ─── Supabase (server-side, admin operations) ───────────────────────
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── Clerk (authentication) ─────────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY="pk_test_your-clerk-key"

# ─── Sanity CMS ─────────────────────────────────────────────────────
VITE_SANITY_PROJECT_ID="your-sanity-project-id"
VITE_SANITY_DATASET="production"
SANITY_API_TOKEN="your-sanity-api-token"

# ─── Google Cloud ────────────────────────────────────────────────────
# GOOGLE_CLOUD_PROJECT="rovacredit"
# GOOGLE_MAPS_API_KEY="your-maps-key"

# ─── Redis (Memorystore) ────────────────────────────────────────────
# REDIS_HOST="10.0.0.x"
# REDIS_PORT="6379"

# ─── WhatsApp Business ──────────────────────────────────────────────
# WHATSAPP_TOKEN="your-whatsapp-token"
# WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
